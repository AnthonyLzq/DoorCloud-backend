{
  "name": "doorcloud-backend",
  "version": "1.0.0",
  "packageManager": "pnpm@10.30.1",
  "main": "src/index.ts",
  "description": "Backend for DoorCloud",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "preservice": "node scripts/openwa/sync-api-key.mjs --optional",
    "service": "nodemon --exitcrash",
    "start": "NODE_PATH=dist node dist/index.js",
    "release": "commit-and-tag-version",
    "test:local": "vitest run --exclude \"**/*.integration.test.ts\"",
    "test:ci": "vitest run --exclude \"**/*.integration.test.ts\"",
    "test:mqtt": "scripts/mosquitto/run-integration-tests.sh",
    "test:mqtt:integration": "vitest run test/mqtt.integration.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "openwa:qr": "node scripts/openwa/qr-sign-in.mjs",
    "openwa:sync-api-key": "node scripts/openwa/sync-api-key.mjs",
    "pub": "nodemon --exec \"DEBUG=DoorCloud:* tsx -r dotenv/config src/pub.ts\""
  },
  "author": "AnthonyLzq <sluzquinosa@uni.pe>",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/debug": "^4.1.7",
    "@types/http-errors": "^2.0.1",
    "@types/node": "^22.20.1",
    "commit-and-tag-version": "^12.6.1",
    "dotenv": "^16.0.3",
    "nodemon": "^2.0.20",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/multipart": "^10.1.0",
    "@supabase/postgrest-js": "^1.1.1",
    "@supabase/supabase-js": "^2.2.3",
    "@vladmandic/human": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "debug": "^4.3.4",
    "fastify": "^5.10.0",
    "fastify-type-provider-zod": "7.0.0",
    "http-errors": "^2.0.0",
    "mqtt": "^5.15.2",
    "onnxruntime-node": "^1.17.0",
    "pino-pretty": "^9.1.1",
    "sharp": "^0.33.0",
    "zod": "^4.4.3"
  },
  "nodemonConfig": {
    "watch": [
      ".env",
      "src"
    ],
    "ext": "ts",
    "ignore": [
      "src/**/*.test.ts"
    ],
    "exec": "DEBUG=DoorCloud:* tsx -r dotenv/config ./src/index.ts"
  },
  "engines": {
    "node": ">=22.20.0 <23",
    "pnpm": ">=10.30.1 <11"
  },
  "directories": {
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnthonyLzq/DoorCloud-backend.git"
  },
  "keywords": [
    "mqqt"
  ],
  "bugs": {
    "url": "https://github.com/AnthonyLzq/DoorCloud-backend/issues"
  },
  "homepage": "https://github.com/AnthonyLzq/DoorCloud-backend#readme",
  "commit-and-tag-version": {
    "skip": {
      "tag": true,
      "commit": true,
      "bump": true
    }
  }
}
