{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "server": {
    "port": 4096
  },
  "permission": {
    "bash": {
      "*": "ask",
      "pnpm *": "allow",
      "git *": "allow",
      "npm *": "allow",
      "node *": "allow",
      "docker *": "allow",
      "rm *": "deny"
    },
    "edit": {
      "*": "allow"
    }
  },
  "formatter": {
    "biome": {
      "command": ["pnpm", "biome", "format", "--write", "$FILE"],
      "extensions": [".js", ".ts", ".jsx", ".tsx", ".json"]
    }
  }
}
