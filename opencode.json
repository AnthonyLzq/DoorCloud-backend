{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "server": {
    "port": 4096
  },
  "permission": {
    "bash": {
      "*": "ask",
      "pnpm *": "allow",
      "git add *": "allow",
      "git stash *": "allow",
      "git mv *": "allow",
      "git commit *": "ask",
      "git merge *": "ask",
      "git reset *": "ask",
      "git rebase *": "ask",
      "git checkout *": "ask",
      "git cherry-pick *": "ask",
      "git push *": "ask",
      "git pull *": "ask",
      "git rm *": "ask",
      "git clean *": "ask",
      "git *": "ask",
      "npm *": "allow",
      "node *": "allow",
      "docker *": "allow",
      "rm *": "deny"
    },
    "edit": {
      "*": "allow"
    }
  },
  "formatter": {
    "biome": {
      "command": ["pnpm", "biome", "format", "--write", "$FILE"],
      "extensions": [".js", ".ts", ".jsx", ".tsx", ".json"]
    }
  },
  "context": {
    "alwaysRead": ["AGENTS.md", "docs/ai/AI_CONTEXT.md"],
    "exclude": [
      "pnpm-lock.yaml",
      "metrics/**",
      "openspec/changes/archive/**",
      "*.png",
      "*.csv"
    ]
  }
}
